# OpenDsStar Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================================================
# Model Provider API Keys
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (for Gemini models via LiteLLM)
GOOGLE_API_KEY=your-google-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key-here
OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_HOST=https://your-resource.azure-api.net

# Hugging Face
HF_TOKEN=hf_your-huggingface-token-here
HF_HOME=/path/to/huggingface/cache

# ============================================================================
# Custom API Provider Configuration
# ============================================================================
# Use these to configure the CustomAPIProvider for any custom endpoint

# Model prefix to handle (e.g., "myapi" for "myapi/model-name")
CUSTOM_API_PREFIX=custom

# Base URL for your custom API (REQUIRED if using CustomAPIProvider)
CUSTOM_API_BASE=https://api.example.com

# API key for authentication (REQUIRED)
CUSTOM_API_KEY=sk-your-custom-api-key

# LiteLLM provider type (default: "openai")
CUSTOM_API_PROVIDER=openai

# Display name for the provider (default: "CustomAPI")
CUSTOM_API_NAME=MyCustomAPI

# ============================================================================
# Milvus Vector Database Configuration
# ============================================================================
# Leave empty to use local milvus-lite (default, macOS/Linux only).
# On Windows or to use a remote server, set to a Milvus URI:
# e.g. http://localhost:19530 (Docker) or https://your-milvus-host:19530
OPENDSSTAR_MILVUS_URI=
